{
  "permissions": {
    "allow": [
      "Bash(unzip -o \"Roomscan-proyecto-habitación.zip\" -d extracted/)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:5173)",
      "Bash(node src/server.js)",
